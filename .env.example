# Cloud Instance Scheduler - Environment Configuration
# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cis
POSTGRES_PORT=5432

# ─── Security (Required) ────────────────────────────────────
# Fernet key for encrypting cloud credentials at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Secret key for signing JWT tokens (use a random 32+ character string)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# ─── Optional Settings ──────────────────────────────────────
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - set to True when running behind a reverse proxy
# CORS_ALLOW_ALL_ORIGINS=False

# Daily pricing update schedule (UTC)
# PRICING_UPDATE_HOUR_UTC=2
# PRICING_UPDATE_MINUTE_UTC=0

# Disable OpenAPI docs in production
# DISABLE_DOCS=False
