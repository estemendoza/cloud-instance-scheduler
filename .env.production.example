# =============================================================================
# Cloud Instance Scheduler - Production Environment
# =============================================================================
# Copy this file to .env on your server and fill in the values
# =============================================================================

# Database
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
POSTGRES_DB=cis

# Security (Required)
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_FERNET_KEY
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_STRING

# CORS - safe to enable behind a reverse proxy
CORS_ALLOW_ALL_ORIGINS=true

# Disable OpenAPI docs in production
DISABLE_DOCS=true

# Pricing update schedule (UTC)
PRICING_UPDATE_HOUR_UTC=2
PRICING_UPDATE_MINUTE_UTC=0
